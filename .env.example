# ─── Base de données ────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/alanya_db"

# ─── JWT ────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET="change-me-access-secret-32chars+"
JWT_REFRESH_SECRET="change-me-refresh-secret-32chars+"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"

# ─── OTP ────────────────────────────────────────────────────────────────────
OTP_TTL_MINUTES="10"

# ─── Serveur ────────────────────────────────────────────────────────────────
PORT=3000
WS_PORT=3001
NODE_ENV=development

# ─── Email (SMTP) ───────────────────────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your@email.com"
SMTP_PASS="your-app-password"
MAIL_FROM="Alanya <no-reply@alanya.app>"

# ─── Stockage media ─────────────────────────────────────────────────────────
MEDIA_STORAGE_DIR="./storage/media"
MEDIA_MAX_SIZE_MB="50"

# ─── IA Gemini ───────────────────────────────────────────────────────────────
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"

# ─── Firebase (Push Notifications) ───────────────────────────────────────────
# Mettre le JSON du compte de service Firebase (minifié sur une ligne)
FIREBASE_SERVICE_ACCOUNT=""

# ─── WebRTC / STUN / TURN ────────────────────────────────────────────────────
STUN_URLS="stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302"
# TURN_URL="turn:your.turn.server:3478"
# TURN_USERNAME="user"
# TURN_CREDENTIAL="password"
